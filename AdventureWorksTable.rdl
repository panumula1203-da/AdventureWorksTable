  <Code>Public Function SumLookup(ByVal items As Object()) As Decimal
    If items Is Nothing Then Return 0
    Dim sum As Decimal = 0
    For Each item As Object In items
        sum += Convert.ToDecimal(item)
    Next
    Return sum
End Function

Public Function GetVariance(ByVal sales As Decimal, ByVal quota As Decimal) As Decimal
    If quota = 0 Then Return 0
    Return (sales - quota) / quota
End Function</Code>

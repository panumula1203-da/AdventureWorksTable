  <DataSets>
    <DataSet Name="dsCountry">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <rd:DesignerState>
          <QueryDefinition xmlns="http://schemas.microsoft.com/ReportingServices/QueryDefinition/Relational">
            <SelectedColumns>
              <ColumnExpression ColumnOwner="DimSalesTerritory" ColumnName="SalesTerritoryCountry" />
            </SelectedColumns>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>SELECT DISTINCT
  DimSalesTerritory.SalesTerritoryCountry
FROM
  DimSalesTerritory ORDER BY DimSalesTerritory.SalesTerritoryCountry</CommandText>
      </Query>
      <Fields>
        <Field Name="SalesTerritoryCountry">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SalesTerritoryCountry</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsYear">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <rd:DesignerState>
          <QueryDefinition xmlns="http://schemas.microsoft.com/ReportingServices/QueryDefinition/Relational">
            <SelectedColumns>
              <ColumnExpression ColumnOwner="DimDate" ColumnName="CalendarYear" />
            </SelectedColumns>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>SELECT DISTINCT 
  DimDate.CalendarYear
FROM
  DimDate ORDER BY DimDate.CalendarYear</CommandText>
      </Query>
      <Fields>
        <Field Name="CalendarYear">
          <rd:TypeName>System.Int16</rd:TypeName>
          <DataField>CalendarYear</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsMain">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Country">
            <Value>=Parameters!Country.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH MonthlySales AS (
    -- 1. Pre-aggregate SALES perfectly by Month so they never duplicate
    SELECT
        de.EmployeeKey,
        de.FirstName + ' ' + de.LastName AS SalesPerson,
        dst.SalesTerritoryCountry,
        dd.CalendarYear,
        dd.MonthNumberOfYear,
        dd.EnglishMonthName,
        DATEPART(QUARTER, dd.FullDateAlternateKey) AS CalendarQuarter,
        SUM(frs.SalesAmount) AS SalesAmount
    FROM FactResellerSales frs
    INNER JOIN DimEmployee de ON frs.EmployeeKey = de.EmployeeKey
    INNER JOIN DimSalesTerritory dst ON frs.SalesTerritoryKey = dst.SalesTerritoryKey
    INNER JOIN DimDate dd ON frs.OrderDateKey = dd.DateKey
    WHERE dd.CalendarYear = @Year AND dst.SalesTerritoryCountry = @Country
    GROUP BY de.EmployeeKey, de.FirstName, de.LastName, dst.SalesTerritoryCountry, dd.CalendarYear, dd.MonthNumberOfYear, dd.EnglishMonthName, DATEPART(QUARTER, dd.FullDateAlternateKey)
),
QuarterlyQuotas AS (
    -- 2. Pre-aggregate QUOTAS perfectly by Quarter so they never duplicate
    SELECT 
        EmployeeKey,
        CalendarYear,
        CalendarQuarter,
        SUM(SalesAmountQuota) AS SalesAmountQuota
    FROM FactSalesQuota
    WHERE CalendarYear = @Year
    GROUP BY EmployeeKey, CalendarYear, CalendarQuarter
)
-- 3. Combine them safely. No row multiplication can physically happen now!
SELECT 
    s.SalesPerson,
    s.SalesTerritoryCountry,
    s.CalendarYear,
    s.MonthNumberOfYear,
    s.EnglishMonthName,
    s.SalesAmount,
    -- Divide the quarterly quota evenly across the monthly sales rows in that quarter
    (q.SalesAmountQuota / COUNT(*) OVER(PARTITION BY s.EmployeeKey, s.CalendarYear, s.CalendarQuarter)) AS SalesAmountQuota
FROM MonthlySales s
LEFT JOIN QuarterlyQuotas q 
    ON s.EmployeeKey = q.EmployeeKey
    AND s.CalendarYear = q.CalendarYear
    AND s.CalendarQuarter = q.CalendarQuarter</CommandText>
      </Query>
      <Fields>
        <Field Name="SalesPerson">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SalesPerson</DataField>
        </Field>
        <Field Name="SalesAmount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>SalesAmount</DataField>
        </Field>
        <Field Name="SalesTerritoryCountry">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SalesTerritoryCountry</DataField>
        </Field>
        <Field Name="CalendarYear">
          <rd:TypeName>System.Int16</rd:TypeName>
          <DataField>CalendarYear</DataField>
        </Field>
        <Field Name="MonthNumberOfYear">
          <rd:TypeName>System.Byte</rd:TypeName>
          <DataField>MonthNumberOfYear</DataField>
        </Field>
        <Field Name="EnglishMonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EnglishMonthName</DataField>
        </Field>
        <Field Name="SalesAmountQuota">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>SalesAmountQuota</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!SalesTerritoryCountry.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=Parameters!Country.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="dsQuota">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Country">
            <Value>=Parameters!Country.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    de.FirstName + ' ' + de.LastName AS SalesPerson,
    fsq.SalesAmountQuota,
    dst.SalesTerritoryCountry,
    dd.CalendarYear
FROM FactSalesQuota fsq
INNER JOIN DimEmployee de 
    ON fsq.EmployeeKey = de.EmployeeKey
INNER JOIN DimSalesTerritory dst 
    ON de.SalesTerritoryKey = dst.SalesTerritoryKey
INNER JOIN DimDate dd 
    ON fsq.DateKey = dd.DateKey
WHERE 
    dd.CalendarYear = @Year 
    AND dst.SalesTerritoryCountry = @Country</CommandText>
      </Query>
      <Fields>
        <Field Name="SalesPerson">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SalesPerson</DataField>
        </Field>
        <Field Name="SalesAmountQuota">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>SalesAmountQuota</DataField>
        </Field>
        <Field Name="SalesTerritoryCountry">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SalesTerritoryCountry</DataField>
        </Field>
        <Field Name="CalendarYear">
          <rd:TypeName>System.Int16</rd:TypeName>
          <DataField>CalendarYear</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
